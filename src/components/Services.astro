---
// Editorial service index — large type rows, cursor-following image reveal.
const services = [
  {
    mode: 'COOLING',
    title: 'AC repair & installation',
    body: 'Manual J load calculations, never guesswork. Systems sized to your square footage, your insulation, your ridge line.',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=720&q=80',
  },
  {
    mode: 'HEATING',
    title: 'Heat pumps & furnaces',
    body: 'Cold-climate heat pumps and dual-fuel setups built for winters that swing forty degrees before lunch.',
    image: 'https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=720&q=80',
  },
  {
    mode: 'AIR QUALITY',
    title: 'Ductwork & filtration',
    body: 'Duct sealing, whole-home dehumidification, and filtration tuned for pollen season in the valley.',
    image: 'https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&w=720&q=80',
  },
  {
    mode: 'MAINTENANCE',
    title: 'Tune-ups & 24/7 emergency',
    body: 'Seasonal 21-point inspections that catch failures before July does. At 2 a.m., the phone still gets answered.',
    image: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&w=720&q=80',
  },
];
---

<section class="services" id="services">
  <div class="container">
    <p class="mode-label" data-reveal>What we do</p>
    <h2 class="services__title" data-reveal>Every mode on your<br />thermostat, mastered.</h2>
  </div>

  <ul class="services__list" role="list" id="services-list">
    {services.map((s, i) => (
      <li class="row" data-image={s.image} data-reveal data-reveal-delay={i * 0.06}>
        <a class="row__link" href="tel:+18283479667">
          <span class="row__mode">{s.mode}</span>
          <span class="row__main">
            <span class="row__title">{s.title}</span>
            <span class="row__body">{s.body}</span>
          </span>
          <span class="row__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- cursor-following preview (desktop only) -->
  <div class="services__preview" id="services-preview" aria-hidden="true">
    <img id="services-preview-img" src={services[0].image} alt="" width="340" height="240" />
  </div>
</section>

<style>
  .services { padding-block: var(--section-pad); position: relative; }

  .services__title {
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 800;
    margin-top: 1rem;
  }

  .services__list {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    border-top: 1px solid var(--ink-line);
  }

  .row { border-bottom: 1px solid var(--ink-line); }

  .row__link {
    width: min(var(--container), 100% - 2 * var(--gutter));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 130px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 2.2rem;
    text-decoration: none;
    transition: padding-left 0.35s ease;
  }

  .row__link:hover { padding-left: 1.2rem; }

  .row__mode {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--text-dim);
  }

  .row:hover .row__mode { color: var(--glacier); }

  .row__main { display: grid; gap: 0.4rem; }

  .row__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .row__body {
    color: var(--text-dim);
    font-size: 0.98rem;
    max-width: 56ch;
  }

  .row__arrow {
    font-size: 1.6rem;
    color: var(--text-dim);
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .row__link:hover .row__arrow {
    transform: translateX(8px);
    color: var(--ember);
  }

  .services__preview {
    position: fixed;
    top: 0;
    left: 0;
    width: 340px;
    border-radius: 14px;
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    z-index: 60;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }

  .services__preview img {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  @media (max-width: 820px) {
    .row__link { grid-template-columns: 1fr auto; }
    .row__mode { display: none; }
    .services__preview { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const list = document.getElementById('services-list');
  const preview = document.getElementById('services-preview');
  const previewImg = document.getElementById('services-preview-img');
  const fine = matchMedia('(pointer: fine)').matches;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (list && preview && previewImg && fine && !reduceMotion) {
    const xTo = gsap.quickTo(preview, 'x', { duration: 0.5, ease: 'power3.out' });
    const yTo = gsap.quickTo(preview, 'y', { duration: 0.5, ease: 'power3.out' });

    list.addEventListener('mousemove', (e) => {
      xTo(e.clientX + 28);
      yTo(e.clientY - 120);
    });

    list.querySelectorAll('.row').forEach((row) => {
      row.addEventListener('mouseenter', () => {
        previewImg.src = row.dataset.image;
        gsap.to(preview, { opacity: 1, scale: 1, duration: 0.35, ease: 'power2.out' });
      });
    });

    list.addEventListener('mouseleave', () => {
      gsap.to(preview, { opacity: 0, scale: 0.94, duration: 0.3, ease: 'power2.in' });
    });
  }
</script>
