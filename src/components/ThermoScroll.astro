---
// The signature: a pinned section where scrolling IS the thermostat.
// The readout scrubs 96.2° → 72.0° and the room's glow cools with it.
---

<section class="thermo" id="story">
  <div class="thermo__pin" id="thermo-pin">
    <div class="thermo__glow" id="thermo-glow" aria-hidden="true"></div>

    <div class="thermo__inner">
      <p class="mode-label">The 72° promise</p>

      <div class="thermo__readout" aria-live="off">
        <span class="thermo__value" id="thermo-value">96.2</span>
        <span class="thermo__unit">°F</span>
      </div>

      <div class="thermo__lines">
        <p class="thermo__line" data-line>July in the valley hits 96°.</p>
        <p class="thermo__line" data-line>Your living room doesn't have to know that.</p>
        <p class="thermo__line" data-line>
          <strong>72.0° — exactly where you left it.</strong>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .thermo {
    /* extra height = scroll runway for the pinned scene */
    position: relative;
  }

  .thermo__pin {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-content: center;
    overflow: hidden;
    text-align: center;
  }

  .thermo__glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(
      55% 55% at 50% 50%,
      rgba(255, 92, 51, var(--glow-a, 0.22)),
      transparent 70%
    );
    /* JS crossfades a cool layer on top via background-color trickery below */
    pointer-events: none;
  }

  .thermo__glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      55% 55% at 50% 50%,
      rgba(87, 196, 255, 0.22),
      transparent 70%
    );
    opacity: var(--cool, 0);
  }

  .thermo__inner {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 1.4rem;
    padding-inline: var(--gutter);
  }

  .thermo__readout {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    line-height: 1;
  }

  .thermo__value {
    font-size: clamp(6rem, 22vw, 17rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .thermo__unit {
    font-size: clamp(1.4rem, 4vw, 3rem);
    color: var(--text-dim);
  }

  .thermo__lines {
    display: grid;
    min-height: 3.4em;
  }

  .thermo__line {
    grid-area: 1 / 1;
    margin: 0;
    font-size: clamp(1.1rem, 2.4vw, 1.6rem);
    color: var(--text-dim);
    opacity: 0;
  }

  .thermo__line strong {
    color: var(--text);
    font-weight: 600;
  }

  html.no-motion .thermo__line:last-child { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .thermo__line { opacity: 0; }
    .thermo__line:last-child { opacity: 1; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const value = document.getElementById('thermo-value');
  const glow = document.getElementById('thermo-glow');
  const pin = document.getElementById('thermo-pin');
  const lines = gsap.utils.toArray('[data-line]');

  if (reduceMotion) {
    if (value) value.textContent = '72.0';
    if (glow) glow.style.setProperty('--cool', '1');
  } else if (pin && value && glow) {
    const state = { t: 96.2 };

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: pin,
        start: 'top top',
        end: '+=220%',
        pin: true,
        scrub: 0.6,
      },
    });

    // the temperature scrubs down across the whole pin
    tl.to(state, {
      t: 72.0,
      ease: 'none',
      duration: 3,
      onUpdate: () => {
        value.textContent = state.t.toFixed(1);
        const progress = (96.2 - state.t) / (96.2 - 72.0);
        glow.style.setProperty('--cool', progress.toFixed(3));
        glow.style.setProperty('--glow-a', (0.22 * (1 - progress)).toFixed(3));
      },
    }, 0);

    // the three lines hand off to each other
    lines.forEach((line, i) => {
      tl.to(line, { opacity: 1, y: 0, duration: 0.5 }, i + 0.1);
      if (i < lines.length - 1) {
        tl.to(line, { opacity: 0, duration: 0.4 }, i + 0.75);
      }
    });
  }
</script>
