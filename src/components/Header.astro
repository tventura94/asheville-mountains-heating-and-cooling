---
const links = [
  { href: '#services', label: 'Services' },
  { href: '#story', label: 'The 72° promise' },
  { href: '#process', label: 'Process' },
  { href: '#reviews', label: 'Reviews' },
];
---

<header class="header" id="site-header">
  <div class="header__inner">
    <a href="/" class="brand" aria-label="Asheville Mountains Heating and Cooling home">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">Asheville Mountains Heating & Cooling</span>
    </a>

    <nav class="nav" aria-label="Main">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <a href="tel:+18283479667" class="header__cta">(828) 347-9667</a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }

  .header.is-scrolled {
    background: rgba(7, 17, 29, 0.78);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--ink-line);
  }

  .header__inner {
    width: min(var(--container), 100% - 2 * var(--gutter));
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .brand__mark {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--temp-line);
  }

  .brand__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
  }

  .brand__name em { font-style: normal; color: var(--glacier); }

  .nav { display: flex; gap: 2rem; }

  .nav a {
    text-decoration: none;
    font-size: 0.92rem;
    color: var(--text-dim);
    transition: color 0.15s ease;
  }

  .nav a:hover, .nav a:focus-visible { color: var(--text); }

  .header__cta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--ink-line);
    border-radius: 999px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .header__cta:hover { border-color: var(--ember); color: var(--ember-soft); }

  @media (max-width: 860px) {
    .nav { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 40);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
