---
const stats = [
  { value: 22, suffix: '', label: 'years in the valley' },
  { value: 1400, suffix: '+', label: 'five-star reviews' },
  { value: 9800, suffix: '+', label: 'systems serviced' },
  { value: 3, suffix: ' hrs', label: 'average response time' },
];
---

<section class="stats">
  <div class="container stats__grid">
    {stats.map((s, i) => (
      <div class="stat" data-reveal data-reveal-delay={i * 0.08}>
        <span class="stat__value">
          <span class="stat__num" data-count={s.value}>0</span>{s.suffix}
        </span>
        <span class="stat__label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats { padding-block: var(--section-pad); }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }

  .stat { display: grid; gap: 0.4rem; }

  .stat__value {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5.6vw, 4.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    background: var(--temp-line);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-variant-numeric: tabular-nums;
  }

  .stat__label {
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  @media (max-width: 820px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('[data-count]').forEach((el) => {
    const end = Number(el.dataset.count);
    if (reduceMotion) {
      el.textContent = end.toLocaleString();
      return;
    }
    const state = { n: 0 };
    gsap.to(state, {
      n: end,
      duration: 1.6,
      ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      onUpdate: () => {
        el.textContent = Math.round(state.n).toLocaleString();
      },
    });
  });
</script>
